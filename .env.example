# Path to the original Cybereye4 project (read-only dependency; do not modify that tree).
CYBEREYE_SRC_ROOT=/home/klzhang/cybereye4

# LLM (OpenAI-compatible). Aligns with common OpenAI env names.
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Model for Planner1 / Planner2 (must be reachable via the client above).
CYBEREYE_LLM_MODEL=gemini-2.5-flash

# Optional: Neo4j / knowledge graph — inherited by cybereye_config when the src project loads.
# KNOWLEDGE_GRAPH_ENABLED=1
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=
